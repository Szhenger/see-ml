# --- CMake & C++ Build Artifacts ---
# Ignores out-of-source builds and compilation databases
build/
build-*/
out/
bin/
lib/
CMakeCache.txt
CMakeFiles/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json

# --- Python & Testing (Integration Suites) ---
# Ignores Python bytecode, virtual environments, and pytest caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
env/
.coverage

# --- External & Third-Party ---
# If CMake FetchContent downloads dependencies locally rather than globally
_deps/
external/*/build/

# --- IDEs & Editor Tooling ---
# Keeps local developer configurations out of the shared repository
.vscode/
.idea/
*.swp
*.swo
.clangd/
.cache/

# --- OS Specific ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
